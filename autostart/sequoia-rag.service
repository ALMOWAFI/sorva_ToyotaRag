[Unit]
Description=Sequoia RAG Assistant
After=network.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/sorva_ToyotaRag
ExecStartPre=/bin/bash -c 'ollama serve &'
ExecStart=/home/pi/sorva_ToyotaRag/.venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
